{
  "crons": [
    {
      "path": "/api/cron/scan-vacancies?secret=${CRON_SECRET}",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/vacancy-hygiene?secret=${CRON_SECRET}",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/pipeline-snapshot?secret=${CRON_SECRET}",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/leaderboard-slack-post?secret=${CRON_SECRET}",
      "schedule": "0 13 * * 1-5"
    },
    {
      "path": "/api/cron/ingest-news-daily?secret=${CRON_SECRET}",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/ingest-news-rolling?secret=${CRON_SECRET}",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/classify-news?secret=${CRON_SECRET}",
      "schedule": "30 * * * *"
    },
    {
      "path": "/api/cron/drain-match-queue?secret=${CRON_SECRET}",
      "schedule": "45 */2 * * *"
    }
  ]
}
