# Database
# For local development with Docker:
DATABASE_URL="postgresql://territory:territory_dev@localhost:5434/territory_plan"

# For Supabase (production):
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# Supabase Auth (required for production)
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[anon-key-from-dashboard]"

# Optional: Urban Institute API (no key needed)
URBAN_INSTITUTE_API_URL="https://educationdata.urban.org/api/v1"

# Maintenance Mode — set to "true" to show coming-soon page
MAINTENANCE_MODE="false"

# Canonical site URL — used for OAuth redirect URIs so they match Google Cloud Console
# Not needed for local dev (falls back to request origin)
NEXT_PUBLIC_SITE_URL="https://plan.fullmindlearning.com"

# Google OAuth
GOOGLE_CALENDAR_CLIENT_ID="[your-google-client-id].apps.googleusercontent.com"
GOOGLE_CALENDAR_CLIENT_SECRET="[your-google-client-secret]"

# Slack OAuth (create at api.slack.com/apps)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Slack MCP (for /feature pipeline approvals)
SLACK_BOT_TOKEN="xoxb-your-bot-token"
SLACK_APP_TOKEN="xapp-your-app-token"

# Scheduler (OpenSearch -> Supabase sync)
OPENSEARCH_HOST="https://your-opensearch-endpoint:9200"
OPENSEARCH_USERNAME="[opensearch-username]"
OPENSEARCH_PASSWORD="[opensearch-password]"
SUPABASE_DB_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# Scheduler monitor — Slack incoming webhook for #data-flow alerts
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

# Token encryption (64 hex chars = 32 bytes for AES-256)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
